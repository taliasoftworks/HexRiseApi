# Server
SERVER_PORT=3000
MONGO_DB_PORT=27025
MONGO_DB2_PORT=27026
MONGO_DB3_PORT=27027
#LOCALHOST=172.17.0.1
LOCALHOST=127.0.0.1

NODE_ENV=development
POSTGRESS_PASSWORD=your_postgres_password
MONGODB_URI=mongodb://hexagonrise_db:27025,hexagonrise_db2:27026,hexagonrise_db3:27027/hexagonrise?replicaSet=rs0

# Keycloak — get the public key from: Realm Settings → Keys → RSA → Public Key
KEYCLOAK_PASSWORD=your_keycloak_password
KEYCLOAK_PORT=8084
KEYCLOAK_PUBLIC_

KEYCLOAK_URL=http://localhost:8084
KEYCLOAK_REALM=hexrise
KEYCLOAK_CLIENT_ID=hexrise-api
